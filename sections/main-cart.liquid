<section class="page-shell cart-page">
  <div class="page-hero">
    <p class="eyebrow">Checkout flow</p>
    <h1>Your bag</h1>
  </div>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <div class="cart-lines">
        {% for item in cart.items %}
          <article class="cart-line">
            <a class="cart-line__media" href="{{ item.url }}">
              {% if item.image %}
                {{ item.image | image_url: width: 240 | image_tag: loading: 'lazy' }}
              {% endif %}
            </a>
            <div class="cart-line__info">
              <a href="{{ item.url }}">{{ item.product.title }}</a>
              <span>{{ item.variant.title }}</span>
              <strong>{{ item.final_line_price | money }}</strong>
            </div>
            <input class="cart-line__qty" name="updates[]" value="{{ item.quantity }}" type="number" min="0">
          </article>
        {% endfor %}
      </div>

      <div class="cart-summary">
        <p>Subtotal</p>
        <strong>{{ cart.total_price | money }}</strong>
        <button class="button-glass" type="submit" name="update">Update bag</button>
        <button class="button-glass button-glass--primary" type="submit" name="checkout">Checkout</button>
      </div>
    </form>
  {% else %}
    <div class="empty-state">
      <p>Your bag is empty.</p>
      <a class="button-glass button-glass--primary" href="{{ routes.all_products_collection_url }}">Start shopping</a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Cart"
}
{% endschema %}
