<section class="ios-hero" aria-label="{{ section.settings.heading | escape }}">
  {% if section.settings.video != blank %}
    <video class="ios-hero__media" autoplay muted loop playsinline preload="metadata">
      {% for source in section.settings.video.sources %}
        <source src="{{ source.url }}" type="{{ source.mime_type }}">
      {% endfor %}
    </video>
  {% elsif section.settings.image != blank %}
    <img
      class="ios-hero__media"
      src="{{ section.settings.image | image_url: width: 2400 }}"
      alt="{{ section.settings.image.alt | escape }}"
      width="{{ section.settings.image.width }}"
      height="{{ section.settings.image.height }}"
      loading="eager"
    >
  {% else %}
    <div class="ios-hero__media ios-hero__fallback"></div>
  {% endif %}

  <div class="hero-noise"></div>
  <div class="hero-depth"></div>
  <div class="hero-blur hero-blur--a"></div>
  <div class="hero-blur hero-blur--b"></div>

  <div class="hero-particles" aria-hidden="true">
    {% for i in (1..18) %}
      <span></span>
    {% endfor %}
  </div>

  <div class="ios-hero__content">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p class="hero-copy">{{ section.settings.text }}</p>
    <div class="hero-actions">
      {% if section.settings.primary_label != blank %}
        <a class="button-glass button-glass--primary" href="{{ section.settings.primary_link }}">
          {{ section.settings.primary_label }}
        </a>
      {% endif %}
      {% if section.settings.secondary_label != blank %}
        <a class="button-glass" href="{{ section.settings.secondary_link }}">
          {{ section.settings.secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>

  <div class="hero-device-card" aria-hidden="true">
    <div class="device-glow"></div>
    <p>{{ section.settings.card_label }}</p>
    <strong>{{ section.settings.card_value }}</strong>
  </div>
</section>

{% schema %}
{
  "name": "iOS cinematic hero",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Background video"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "LUMA OS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fluid luxury, engineered for now."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A cinematic storefront with liquid glass, precise motion, and a premium shopping flow built for Shopify."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button",
      "default": "Shop the drop"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "text",
      "id": "card_label",
      "label": "Floating card label",
      "default": "New collection"
    },
    {
      "type": "text",
      "id": "card_value",
      "label": "Floating card value",
      "default": "AURA 01"
    }
  ],
  "presets": [
    {
      "name": "iOS cinematic hero"
    }
  ]
}
{% endschema %}
