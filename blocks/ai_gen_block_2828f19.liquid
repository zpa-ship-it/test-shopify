{% doc %}
  @prompt
    pourquoi moi et pas une autre marque
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-why-us-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-why-us-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-why-us-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.spacing_between_items }}px;
  }

  .ai-why-us-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    font-weight: 700;
  }

  .ai-why-us-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-why-us-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.spacing_between_items }}px;
    margin-top: {{ block.settings.spacing_between_items }}px;
  }

  .ai-why-us-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-why-us-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-why-us-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background_color }};
    border-radius: 50%;
    color: {{ block.settings.icon_color }};
  }

  .ai-why-us-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
  }

  .ai-why-us-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_title_size }}px;
    color: {{ block.settings.item_title_color }};
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .ai-why-us-item-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_text_size }}px;
    color: {{ block.settings.item_text_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-why-us-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-why-us-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-why-us-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }
  }
{% endstyle %}

<why-us-{{ ai_gen_id }} class="ai-why-us-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-why-us-container-{{ ai_gen_id }}">
    <div class="ai-why-us-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-why-us-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <div class="ai-why-us-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
      {% endif %}
    </div>

    <div class="ai-why-us-grid-{{ ai_gen_id }}">
      {% if block.settings.show_reason_1 %}
        <div class="ai-why-us-item-{{ ai_gen_id }}">
          <div class="ai-why-us-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          {% if block.settings.reason_1_title != blank %}
            <h3 class="ai-why-us-item-title-{{ ai_gen_id }}">{{ block.settings.reason_1_title }}</h3>
          {% endif %}
          {% if block.settings.reason_1_text != blank %}
            <div class="ai-why-us-item-text-{{ ai_gen_id }}">{{ block.settings.reason_1_text }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_reason_2 %}
        <div class="ai-why-us-item-{{ ai_gen_id }}">
          <div class="ai-why-us-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          {% if block.settings.reason_2_title != blank %}
            <h3 class="ai-why-us-item-title-{{ ai_gen_id }}">{{ block.settings.reason_2_title }}</h3>
          {% endif %}
          {% if block.settings.reason_2_text != blank %}
            <div class="ai-why-us-item-text-{{ ai_gen_id }}">{{ block.settings.reason_2_text }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_reason_3 %}
        <div class="ai-why-us-item-{{ ai_gen_id }}">
          <div class="ai-why-us-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          {% if block.settings.reason_3_title != blank %}
            <h3 class="ai-why-us-item-title-{{ ai_gen_id }}">{{ block.settings.reason_3_title }}</h3>
          {% endif %}
          {% if block.settings.reason_3_text != blank %}
            <div class="ai-why-us-item-text-{{ ai_gen_id }}">{{ block.settings.reason_3_text }}</div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_reason_4 %}
        <div class="ai-why-us-item-{{ ai_gen_id }}">
          <div class="ai-why-us-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          {% if block.settings.reason_4_title != blank %}
            <h3 class="ai-why-us-item-title-{{ ai_gen_id }}">{{ block.settings.reason_4_title }}</h3>
          {% endif %}
          {% if block.settings.reason_4_text != blank %}
            <div class="ai-why-us-item-text-{{ ai_gen_id }}">{{ block.settings.reason_4_text }}</div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</why-us-{{ ai_gen_id }}>

<script>
  (function() {
    class WhyUs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('.ai-why-us-item-{{ ai_gen_id }}');
        this.setupObserver();
      }

      setupObserver() {
        const options = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }, index * 100);
              observer.unobserve(entry.target);
            }
          });
        }, options);

        this.items.forEach((item) => {
          item.style.opacity = '0';
          item.style.transform = 'translateY(20px)';
          item.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          observer.observe(item);
        });
      }
    }

    customElements.define('why-us-{{ ai_gen_id }}', WhyUs{{ ai_gen_id }});
  })();
</script>

