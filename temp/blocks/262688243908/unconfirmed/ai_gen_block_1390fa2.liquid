{% doc %}
  @prompt
    je veut pour montrer les avis
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-reviews-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-reviews-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-reviews-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-reviews-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-review-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-review-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-review-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .ai-review-avatar-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: {{ block.settings.avatar_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 600;
    color: {{ block.settings.avatar_text_color }};
    flex-shrink: 0;
  }

  .ai-review-author-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-review-author-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.author_color }};
    margin: 0 0 4px;
  }

  .ai-review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-review-star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    color: {{ block.settings.star_color }};
  }

  .ai-review-star-empty-{{ ai_gen_id }} {
    color: {{ block.settings.star_empty_color }};
  }

  .ai-review-date-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.date_color }};
    margin-bottom: 12px;
  }

  .ai-review-text-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-review-verified-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: {{ block.settings.verified_color }};
    margin-top: 12px;
  }

  .ai-review-verified-icon-{{ ai_gen_id }} {
    width: 14px;
    height: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-container-{{ ai_gen_id }} {
      padding: 30px 16px;
    }

    .ai-reviews-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-reviews-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-reviews-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }
  }
{% endstyle %}

<customer-reviews-{{ ai_gen_id }} class="ai-reviews-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reviews-header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-reviews-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    {% if block.settings.subtitle != blank %}
      <p class="ai-reviews-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="ai-reviews-grid-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign author_key = 'review_' | append: i | append: '_author'
        assign rating_key = 'review_' | append: i | append: '_rating'
        assign text_key = 'review_' | append: i | append: '_text'
        assign date_key = 'review_' | append: i | append: '_date'
        assign verified_key = 'review_' | append: i | append: '_verified'

        assign author = block.settings[author_key]
        assign rating = block.settings[rating_key]
        assign text = block.settings[text_key]
        assign date = block.settings[date_key]
        assign verified = block.settings[verified_key]
      %}

      {% if author != blank %}
        <div class="ai-review-card-{{ ai_gen_id }}">
          <div class="ai-review-header-{{ ai_gen_id }}">
            <div class="ai-review-avatar-{{ ai_gen_id }}">
              {{ author | slice: 0 | upcase }}
            </div>
            <div class="ai-review-author-info-{{ ai_gen_id }}">
              <p class="ai-review-author-{{ ai_gen_id }}">{{ author }}</p>
              <div class="ai-review-stars-{{ ai_gen_id }}">
                {% for star in (1..5) %}
                  {% if star <= rating %}
                    <svg class="ai-review-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% else %}
                    <svg class="ai-review-star-{{ ai_gen_id }} ai-review-star-empty-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>

          {% if date != blank %}
            <div class="ai-review-date-{{ ai_gen_id }}">{{ date }}</div>
          {% endif %}

          {% if text != blank %}
            <p class="ai-review-text-{{ ai_gen_id }}">{{ text }}</p>
          {% endif %}

          {% if verified %}
            <div class="ai-review-verified-{{ ai_gen_id }}">
              <svg class="ai-review-verified-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
              </svg>
              Achat vérifié
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</customer-reviews-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerReviews{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeReviews();
      }

      initializeReviews() {
        const cards = this.querySelectorAll('.ai-review-card-{{ ai_gen_id }}');
        cards.forEach((card, index) => {
          card.style.animationDelay = `${index * 0.1}s`;
        });
      }
    }

    customElements.define('customer-reviews-{{ ai_gen_id }}', CustomerReviews{{ ai_gen_id }});
  })();
</script>

