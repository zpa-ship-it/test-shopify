{% doc %}
  @prompt
    pourquoi acheter maintenant
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-buy-now-{{ ai_gen_id }} {
    display: block;
    padding: 40px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-buy-now-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-buy-now-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-buy-now-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    font-weight: 700;
  }

  .ai-buy-now-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-buy-now-reasons-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: 20px;
  }

  .ai-buy-now-reason-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-buy-now-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background_color }};
    border-radius: 50%;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }

  .ai-buy-now-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
  }

  .ai-buy-now-reason-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.reason_title_size }}px;
    color: {{ block.settings.reason_title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-buy-now-reason-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.reason_text_size }}px;
    color: {{ block.settings.reason_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-buy-now-reasons-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-buy-now-{{ ai_gen_id }} {
      padding: 24px;
    }
  }
{% endstyle %}

<div class="ai-buy-now-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-buy-now-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-buy-now-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-buy-now-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-buy-now-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-buy-now-reasons-{{ ai_gen_id }}">
      {% if block.settings.reason_1_enabled %}
