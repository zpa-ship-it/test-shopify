{% doc %}
  @prompt
    avis des gens 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-reviews-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-reviews-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-reviews-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
  }

  .ai-reviews-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-reviews-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: 24px;
    margin-bottom: 32px;
  }

  .ai-review-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-review-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .ai-review-avatar-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: {{ block.settings.avatar_background }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 600;
    color: {{ block.settings.avatar_text_color }};
    flex-shrink: 0;
  }

  .ai-review-author-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-review-author-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.author_color }};
    margin: 0 0 4px;
  }

  .ai-review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-review-star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    color: {{ block.settings.star_color }};
  }

  .ai-review-star-empty-{{ ai_gen_id }} {
    color: {{ block.settings.star_empty_color }};
  }

  .ai-review-text-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: {{ block.settings.review_text_color }};
    margin: 0 0 12px;
  }

  .ai-review-date-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.date_color }};
  }

  .ai-reviews-summary-{{ ai_gen_id }} {
    text-align: center;
    padding: 24px;
    background-color: {{ block.settings.summary_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
  }

  .ai-reviews-average-{{ ai_gen_id }} {
    font-size: 48px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 8px;
  }

  .ai-reviews-summary-stars-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 8px;
  }

  .ai-reviews-summary-star-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    color: {{ block.settings.star_color }};
  }

  .ai-reviews-count-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.subtitle_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-reviews-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-reviews-average-{{ ai_gen_id }} {
      font-size: 36px;
    }
  }
{% endstyle %}

<customer-reviews-{{ ai_gen_id }} class="ai-reviews-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reviews-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-reviews-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-reviews-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-reviews-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-reviews-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign review_enabled_key = 'review_' | append: i | append: '_enabled'
          assign review_author_key = 'review_' | append: i | append: '_author'
          assign review_rating_key = 'review_' | append: i | append: '_rating'
          assign review_text_key = 'review_' | append: i | append: '_text'
          assign review_date_key = 'review_' | append: i | append: '_date'

          assign review_enabled = block.settings[review_enabled_key]
          assign review_author = block.settings[review_author_key]
          assign review_rating = block.settings[review_rating_key]
          assign review_text = block.settings[review_text_key]
          assign review_date = block.settings[review_date_key]
        %}

        {% if review_enabled %}
          <div class="ai-review-card-{{ ai_gen_id }}">
            <div class="ai-review-header-{{ ai_gen_id }}">
              <div class="ai-review-avatar-{{ ai_gen_id }}">
                {% if review_author != blank %}
                  {{ review_author | slice: 0 | upcase }}
                {% else %}
                  ?
                {% endif %}
              </div>
              <div class="ai-review-author-info-{{ ai_gen_id }}">
                <p class="ai-review-author-{{ ai_gen_id }}">
                  {% if review_author != blank %}
                    {{ review_author }}
                  {% else %}
                    Client
                  {% endif %}
                </p>
                <div class="ai-review-stars-{{ ai_gen_id }}">
                  {% for star in (1..5) %}
                    {% if star <= review_rating %}
                      <svg class="ai-review-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {% else %}
                      <svg class="ai-review-star-{{ ai_gen_id }} ai-review-star-empty-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            </div>
            {% if review_text != blank %}
              <p class="ai-review-text-{{ ai_gen_id }}">{{ review_text }}</p>
            {% endif %}
            {% if review_date != blank %}
              <p class="ai-review-date-{{ ai_gen_id }}">{{ review_date }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_summary %}
      <div class="ai-reviews-summary-{{ ai_gen_id }}">
        <div class="ai-reviews-average-{{ ai_gen_id }}">{{ block.settings.average_rating }}</div>
        <div class="ai-reviews-summary-stars-{{ ai_gen_id }}">
          {% assign average_floor = block.settings.average_rating | floor %}
          {% for star in (1..5) %}
            {% if star <= average_floor %}
              <svg class="ai-reviews-summary-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% else %}
              <svg class="ai-reviews-summary-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" opacity="0.3">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endif %}
          {% endfor %}
        </div>
        <p class="ai-reviews-count-{{ ai_gen_id }}">Basé sur {{ block.settings.total_reviews }} avis</p>
      </div>
    {% endif %}
  </div>
</customer-reviews-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerReviews{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('customer-reviews-{{ ai_gen_id }}', CustomerReviews{{ ai_gen_id }});
  })();
</script>

