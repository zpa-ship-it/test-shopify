{% doc %}
  @prompt
    apple ios featuresa
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ios-features-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background: {{ block.settings.background_color }};
  }

  .ai-ios-features-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-ios-features-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-ios-features-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 15px;
    font-weight: 700;
  }

  .ai-ios-features-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    opacity: 0.8;
  }

  .ai-ios-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
  }

  .ai-ios-feature-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 35px 25px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-ios-feature-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .ai-ios-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 20px;
    background: {{ block.settings.icon_background }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ios-feature-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    fill: {{ block.settings.icon_color }};
  }

  .ai-ios-feature-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    color: {{ block.settings.feature_title_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-ios-feature-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_text_size }}px;
    color: {{ block.settings.feature_text_color }};
    margin: 0;
    line-height: 1.6;
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .ai-ios-features-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .ai-ios-features-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-ios-features-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }
  }
{% endstyle %}

<ios-features-{{ ai_gen_id }} class="ai-ios-features-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ios-features-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-ios-features-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-ios-features-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-ios-features-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-ios-features-grid-{{ ai_gen_id }}">
      {% if block.settings.feature_1_enabled %}
        <div class="ai-ios-feature-card-{{ ai_gen_id }}">
          <div class="ai-ios-feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <h3 class="ai-ios-feature-name-{{ ai_gen_id }}">{{ block.settings.feature_1_title }}</h3>
          <p class="ai-ios-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_1_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.feature_2_enabled %}
        <div class="ai-ios-feature-card-{{ ai_gen_id }}">
          <div class="ai-ios-feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
            </svg>
          </div>
          <h3 class="ai-ios-feature-name-{{ ai_gen_id }}">{{ block.settings.feature_2_title }}</h3>
          <p class="ai-ios-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_2_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.feature_3_enabled %}
        <div class="ai-ios-feature-card-{{ ai_gen_id }}">
          <div class="ai-ios-feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M20 2H4c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM8 20H4v-4h4v4zm0-6H4v-4h4v4zm0-6H4V4h4v4zm6 12h-4v-4h4v4zm0-6h-4v-4h4v4zm0-6h-4V4h4v4zm6 12h-4v-4h4v4zm0-6h-4v-4h4v4zm0-6h-4V4h4v4z"/>
            </svg>
          </div>
          <h3 class="ai-ios-feature-name-{{ ai_gen_id }}">{{ block.settings.feature_3_title }}</h3>
          <p class="ai-ios-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_3_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.feature_4_enabled %}
        <div class="ai-ios-feature-card-{{ ai_gen_id }}">
          <div class="ai-ios-feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M13 2.05v3.03c3.39.49 6 3.39 6 6.92 0 .9-.18 1.75-.48 2.54l2.6 1.53c.56-1.24.88-2.62.88-4.07 0-5.18-3.95-9.45-9-9.95zM12 19c-3.87 0-7-3.13-7-7 0-3.53 2.61-6.43 6-6.92V2.05c-5.06.5-9 4.76-9 9.95 0 5.52 4.47 10 9.99 10 3.31 0 6.24-1.61 8.06-4.09l-2.6-1.53C16.17 17.98 14.21 19 12 19z"/>
            </svg>
          </div>
          <h3 class="ai-ios-feature-name-{{ ai_gen_id }}">{{ block.settings.feature_4_title }}</h3>
          <p class="ai-ios-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_4_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.feature_5_enabled %}
        <div class="ai-ios-feature-card-{{ ai_gen_id }}">
          <div class="ai-ios-feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
          </div>
          <h3 class="ai-ios-feature-name-{{ ai_gen_id }}">{{ block.settings.feature_5_title }}</h3>
          <p class="ai-ios-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_5_description }}</p>
        </div>
      {% endif %}

      {% if block.settings.feature_6_enabled %}
        <div class="ai-ios-feature-card-{{ ai_gen_id }}">
          <div class="ai-ios-feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </div>
          <h3 class="ai-ios-feature-name-{{ ai_gen_id }}">{{ block.settings.feature_6_title }}</h3>
          <p class="ai-ios-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_6_description }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</ios-features-{{ ai_gen_id }}>

<script>
  (function() {
    class IosFeatures{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-ios-feature-card-{{ ai_gen_id }}');
        this.setupObserver();
      }

      setupObserver() {
        const options = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }, index * 100);
              observer.unobserve(entry.target);
            }
          });
        }, options);

        this.cards.forEach((card) => {
          card.style.opacity = '0';
          card.style.transform = 'translateY(20px)';
          card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          observer.observe(card);
        });
      }
    }

    customElements.define('ios-features-{{ ai_gen_id }}', IosFeatures{{ ai_gen_id }});
  })();
</script>

